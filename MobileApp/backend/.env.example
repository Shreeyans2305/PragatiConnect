# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# DynamoDB Tables
DYNAMODB_TABLE_USERS=pragati-users
DYNAMODB_TABLE_CONVERSATIONS=pragati-conversations
DYNAMODB_TABLE_ESTIMATES=pragati-estimates

# S3 Configuration
S3_BUCKET_IMAGES=pragati-images

# Amazon Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_KNOWLEDGE_BASE_ID=your_kb_id_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# OTP Configuration (set to true for development)
OTP_MOCK_MODE=true
OTP_MOCK_CODE=123456

# App Configuration
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
